# Telegram Bot Credentials (Required)
# You MUST provide API_ID and API_HASH.
# Then, provide EITHER a BOT_TOKEN (for standard bot mode) OR a SESSION_STRING (for user account mode).
BOT_TOKEN=your_bot_token_here
# SESSION_STRING=1Bjwpa... (Optional: Use this instead of BOT_TOKEN to login as a real user to bypass some channel restrictions)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# User Authorization (Required)
# Comma-separated list of Telegram user IDs allowed to use the bot
ALLOWED_USERS=123456789,987654321

# Bot Settings (Optional)
DOWNLOAD_PATH=downloads
# Default is 3 to avoid triggering Telegram API FloodWait limitations.
MAX_CONCURRENT_DOWNLOADS=3

# Timeout for a single download in seconds (Default: 7200 seconds / 2 hours)
# DOWNLOAD_TIMEOUT=7200

CACHE_TTL=30
UPDATE_INTERVAL=1

# Group Support (Optional)
# Set to true to allow bot usage in groups
ALLOW_GROUP_MESSAGES=false

# Auto Cleanup (Optional)
# Number of days to keep downloaded files (0 = disabled)
AUTO_CLEANUP_DAYS=0

# Web Dashboard (Optional)
# Dashboard port (Default: 8080)
# WEB_PORT=8080
# Set a password to require HTTP Basic Auth for the dashboard.
# Leave unset/empty for no authentication (default). Any username works; only the password is checked.
# WEB_PASSWORD=your_dashboard_password
